  <!-- ============ PAGE HERO ============ -->
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="index.html">Home</a> / Contact</p>
      <h1 style="color:#fff;">Get In Touch</h1>
    </div>
  </section>

  <!-- ============ CONTACT GRID ============ -->
  <section class="section-pad bg-cream">
    <div class="container contact-grid">

      <div class="reveal">
        <p class="eyebrow">Send A Message</p>
        <h2 style="margin-top:14px;">We'll Reply Within 1 Business Day</h2>
        <form id="contact-form" style="margin-top:36px;">
          <div class="field-row">
            <div class="field">
              <label for="c-name">Full Name</label>
              <input type="text" id="c-name" required>
            </div>
            <div class="field">
              <label for="c-email">Email Address</label>
              <input type="email" id="c-email" required>
            </div>
          </div>
          <div class="field">
            <label for="c-subject">Subject</label>
            <select id="c-subject">
              <option>Order Enquiry</option>
              <option>Sizing Help</option>
              <option>Returns &amp; Exchanges</option>
              <option>Wholesale</option>
              <option>Something Else</option>
            </select>
          </div>
          <div class="field">
            <label for="c-message">Message</label>
            <textarea id="c-message" required></textarea>
          </div>
          <button type="submit" class="btn btn-gold">Send Message</button>
          <p class="form-success" id="contact-success">Message sent — we'll reply within 1 business day.</p>
        </form>
      </div>

      <div class="reveal">
        <p class="eyebrow">Visit Or Write</p>
        <h2 style="margin-top:14px;">Customer Care</h2>
        <div style="margin-top:30px;color:var(--c-secondary);">
          <p style="margin-bottom:18px;"><strong style="color:var(--c-primary);">Email</strong><br>care@rangeborn.co.uk</p>
          <p style="margin-bottom:18px;"><strong style="color:var(--c-primary);">Phone</strong><br>+44 (0) 20 7946 0958 — Mon–Fri, 9am–6pm GMT</p>
          <p style="margin-bottom:18px;"><strong style="color:var(--c-primary);">Studio</strong><br>14 Saddle Yard, London, EC2A 4NE, United Kingdom</p>
        </div>

        <div style="margin-top:50px;">
          <h4 style="font-family:var(--f-subheading);text-transform:uppercase;font-size:.95rem;letter-spacing:.06em;margin-bottom:18px;">Frequently Asked</h4>
          <div class="accordion-mini">
            <div class="faq-item">
              <div class="faq-q">How long does shipping take?<span class="plus">+</span></div>
              <div class="faq-a"><p>UK orders arrive in 2–4 working days. International shipping takes 5–10 working days depending on destination.</p></div>
            </div>
            <div class="faq-item">
              <div class="faq-q">What is your returns policy?<span class="plus">+</span></div>
              <div class="faq-a"><p>We offer 30-day free returns on all unworn items with tags attached. Start a return from your account or contact us directly.</p></div>
            </div>
            <div class="faq-item">
              <div class="faq-q">Do you ship internationally?<span class="plus">+</span></div>
              <div class="faq-a"><p>Yes — we ship across the UK, EU, US and Canada. Duties and taxes are calculated at checkout where applicable.</p></div>
            </div>
            <div class="faq-item">
              <div class="faq-q">How do I find my size?<span class="plus">+</span></div>
              <div class="faq-a"><p>Each product page includes a detailed size guide. If you're between sizes, our team is happy to advise — just send us a message.</p></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

</main>

