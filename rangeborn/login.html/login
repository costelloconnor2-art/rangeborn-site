<main>
  <section class="section-pad" style="padding-top:160px;">
    <div class="container auth-wrap">

      <div class="text-center" style="margin-bottom:40px;">
        <p class="eyebrow" style="justify-content:center">Welcome Back</p>
        <h1 style="margin-top:14px;">My Account</h1>
      </div>

      <div class="auth-tabs">
        <button type="button" class="auth-tab active" data-tab="panel-signin">Sign In</button>
        <button type="button" class="auth-tab" data-tab="panel-create">Create Account</button>
      </div>

      <!-- SIGN IN -->
      <div class="auth-panel active" id="panel-signin">
        <form data-auth-form>
          <div class="field">
            <label for="si-email">Email Address</label>
            <input type="email" id="si-email" required>
          </div>
          <div class="field">
            <label for="si-password">Password</label>
            <input type="password" id="si-password" required>
          </div>
          <div class="auth-row-between">
            <label class="checkbox-row" style="margin-bottom:0;"><input type="checkbox"> Remember me</label>
            <a href="contact.html">Forgot password?</a>
          </div>
          <button type="submit" class="btn btn-gold btn-block">Sign In</button>
        </form>
        <div class="divider-or">or</div>
        <button type="button" class="btn btn-outline btn-block" style="color:var(--c-primary);border-color:rgba(22,22,22,.25);">Continue With Google</button>
      </div>

      <!-- CREATE ACCOUNT -->
      <div class="auth-panel" id="panel-create">
        <form data-auth-form>
          <div class="field-row">
            <div class="field">
              <label for="ca-first">First Name</label>
              <input type="text" id="ca-first" required>
            </div>
            <div class="field">
              <label for="ca-last">Last Name</label>
              <input type="text" id="ca-last" required>
            </div>
          </div>
          <div class="field">
            <label for="ca-email">Email Address</label>
            <input type="email" id="ca-email" required>
          </div>
          <div class="field">
            <label for="ca-password">Password</label>
            <input type="password" id="ca-password" required>
          </div>
          <label class="checkbox-row"><input type="checkbox"> Sign me up for 10% off and exclusive drops</label>
          <button type="submit" class="btn btn-gold btn-block">Create Account</button>
        </form>
      </div>

    </div>
  </section>
</main>

