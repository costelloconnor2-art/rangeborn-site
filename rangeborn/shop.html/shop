<main>

  <!-- ============ PAGE HERO ============ -->
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="index.html">Home</a> / Shop</p>
      <h1 style="color:#fff;">Shop All</h1>
    </div>
  </section>

  <!-- ============ SHOP LAYOUT ============ -->
  <section class="section-pad bg-cream">
    <div class="container">

      <button type="button" class="filter-toggle btn btn-outline" style="color:var(--c-primary);border-color:rgba(22,22,22,.25);margin-bottom:24px;">Filter &amp; Sort</button>

      <div class="shop-layout">

        <!-- FILTER SIDEBAR -->
        <aside class="filters">
          <div class="filter-group">
            <h4>Gender</h4>
            <label class="filter-option"><input type="radio" name="filter-gender" value="all" checked> All</label>
            <label class="filter-option"><input type="radio" name="filter-gender" value="mens"> Mens</label>
            <label class="filter-option"><input type="radio" name="filter-gender" value="womens"> Womens</label>
          </div>

          <div class="filter-group">
            <h4>Category</h4>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="mens-tees"> Mens Graphic Tees</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="mens-hoodies"> Mens Hoodies</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="mens-jackets"> Mens Jackets</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="mens-flannel"> Mens Flannel Shirts</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="mens-cowboy-hats"> Mens Cowboy Hats</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="mens-caps"> Mens Caps</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="womens-tees"> Womens Graphic Tees</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="womens-hoodies"> Womens Oversized Hoodies</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="womens-crop-tees"> Womens Crop Tees</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="womens-jackets"> Womens Jackets</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="womens-accessories"> Womens Accessories</label>
            <label class="filter-option"><input type="checkbox" name="filter-category" value="womens-hats"> Womens Hats</label>
          </div>

          <div class="filter-group">
            <h4>Collection</h4>
            <label class="filter-option"><input type="checkbox" name="filter-collection" value="western-heritage"> Western Heritage</label>
            <label class="filter-option"><input type="checkbox" name="filter-collection" value="long-ride-club"> Long Ride Club</label>
            <label class="filter-option"><input type="checkbox" name="filter-collection" value="outlaw-country"> Outlaw Country</label>
            <label class="filter-option"><input type="checkbox" name="filter-collection" value="midnight-range"> Midnight Range</label>
          </div>

          <div class="filter-group" style="border-bottom:none;">
            <h4>Price</h4>
            <div class="price-range">
              <input type="range" id="price-range" min="38" max="260" value="260">
            </div>
            <p id="price-range-value" style="font-size:.82rem;color:var(--c-secondary);margin-top:8px;">Up to £260</p>
          </div>

          <a href="shop.html" class="clear-filters">Clear All Filters</a>
        </aside>

        <!-- PRODUCT GRID -->
        <div>
          <div class="products-toolbar">
            <span class="results-count" id="results-count">0 pieces</span>
            <div class="toolbar-right">
              <input type="text" id="shop-search" placeholder="Search this shop…" style="border:1px solid rgba(22,22,22,.15);border-radius:4px;padding:10px 14px;font-size:.85rem;background:#fff;min-width:180px;">
              <div class="select-wrap">
                <select id="sort-select">
                  <option value="featured">Featured</option>
                  <option value="newest">Newest</option>
                  <option value="price-asc">Price: Low to High</option>
                  <option value="price-desc">Price: High to Low</option>
                </select>
              </div>
            </div>
          </div>

          <div class="product-grid" id="shop-grid"></div>

          <div class="empty-state" id="empty-state">
            <svg viewBox="0 0 24 24"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/><path d="M12 11v10"/></svg>
            <h3>No Pieces Found</h3>
            <p style="margin-top:10px;color:var(--c-secondary);">Try adjusting your filters or search a different term.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

